{
  "manifest_version": 3,
  "name": "Blander | News Headline Neutralizer",
  "version": "1.0.4",
  "description": "This Chrome extension simplifies NYTimes headlines for a more neutral reading experience.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "*://*.nytimes.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.nytimes.com/*"],
      "js": ["casing.js", "content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/bored16.png",
      "48": "images/bored48.png",
      "128": "images/bored128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "images/bored16.png",
    "48": "images/bored48.png",
    "128": "images/bored128.png"
  }
} 